package langchain:quickjs@0.1.0;

/// Shared types used across the runtime and context interfaces.
interface types {
    /// A marshaled JS value. Primitives transit directly; objects and arrays
    /// are structured. Functions, symbols, class instances with prototypes,
    /// and circular references cannot be represented here — use `handle`
    /// (see the `context` interface) for those.
    variant value {
        /// JS `null`.
        %null,
        /// JS `undefined`. Distinct from null, per JS semantics.
        undefined,
        %boolean(bool),
        /// JS number. All JS numbers are IEEE-754 f64.
        number(f64),
        /// JS BigInt, serialized as a decimal string (WIT has no native bigint).
        bigint(string),
        %string(string),
        /// Maps to `Uint8Array` on the JS side and `bytes` on the host side.
        bytes(list<u8>),
        list(list<value>),
        /// Plain object. Ordered to preserve insertion order (JS semantic).
        object(list<tuple<string, value>>),
    }

    /// A JS exception surfaced to the host. Covers both thrown `Error`
    /// subclasses and thrown primitives (in which case `name` is "Error"
    /// and `message` is the coerced string form).
    record js-error {
        name: string,
        message: string,
        stack: option<string>,
    }

    /// Flags controlling how code is evaluated.
    flags eval-flags {
        /// Evaluate as an ES module (vs. a script). Enables `import`/`export`
        /// and top-level `await`.
        module,
        /// Compile without executing. The result is a callable function
        /// handle you can invoke later.
        compile-only,
        /// Force strict mode regardless of source pragma.
        strict,
    }
}

/// A QuickJS runtime owns the JS heap and the memory/stack limits.
/// All contexts created from the same runtime share its heap. If you need
/// isolated heaps (for per-agent isolation), create one runtime per context.
interface runtime {
    use types.{js-error};

    resource runtime {
        constructor();

        /// Set the JS heap memory limit in bytes. Default is unlimited
        /// (up to the wasm instance's linear memory ceiling). Setting this
        /// to a small value is strongly recommended in agent contexts.
        set-memory-limit: func(bytes: u64);

        /// Set the maximum JS call stack size in bytes.
        set-stack-limit: func(bytes: u64);

        /// Execute any pending jobs (Promise reactions, queued microtasks)
        /// until the queue is empty or an exception is raised. Returns the
        /// number of jobs that ran. This is what you drive between
        /// `host-call` completions when running async JS.
        run-pending-jobs: func() -> result<u32, js-error>;

        /// True if there are jobs ready to run without host intervention.
        has-pending-jobs: func() -> bool;

        /// Install the interrupt handler. Once installed, QuickJS will call
        /// the host's `host-interrupt` import periodically; returning true
        /// from that import aborts the currently executing JS code with an
        /// `InterruptError`. Call this once per runtime after construction.
        install-interrupt-handler: func();
    }
}

/// JS execution contexts, handles to in-guest values, and host-registered
/// functions.
interface context {
    use types.{value, js-error, eval-flags};
    use runtime.{runtime};

    resource context {
        /// Create a new context bound to the given runtime. Cheap —
        /// create as many as you want per runtime. Contexts share the
        /// runtime's heap; handles from one context are not valid in another.
        constructor(rt: borrow<runtime>);

        /// Evaluate code and marshal the result out as a `value`.
        /// Fast path. Fails with a non-JS error if the result contains
        /// functions, symbols, or circular references — in that case
        /// retry with `eval-handle`.
        eval: func(code: string, flags: eval-flags) -> result<value, js-error>;

        /// Evaluate code and return the result as a handle living in
        /// guest memory. Use when you need to hold the value across
        /// multiple calls, traverse it lazily, or it contains closures.
        eval-handle: func(code: string, flags: eval-flags)
            -> result<handle, js-error>;

        /// Set a global variable. The value is deep-copied into the context.
        set-global: func(name: string, val: value) -> result<_, js-error>;

        /// Same as `set-global` but takes a handle (no re-marshaling).
        set-global-handle: func(name: string, val: borrow<handle>)
            -> result<_, js-error>;

        /// Get a global as a marshaled value.
        get-global: func(name: string) -> result<value, js-error>;

        /// Get a global as a handle.
        get-global-handle: func(name: string) -> result<handle, js-error>;

        /// Register `name` as a JS global function that, when called,
        /// dispatches to the host via `host-call` with the given `fn-id`.
        /// The host is responsible for the ID → callable registry;
        /// `fn-id` is opaque to the component.
        register-host-function: func(name: string, fn-id: u32)
            -> result<_, js-error>;
    }

    /// Opaque handle to a JS value in guest memory. Handles must be
    /// explicitly dropped (or tied to an RAII wrapper in the host
    /// language's generated bindings) — leaking them leaks guest memory.
    /// A handle is only valid in the context that created it.
    resource handle {
        /// Get a property by string key.
        get-prop: func(key: string) -> result<handle, js-error>;

        /// Get a property by integer index (for arrays and array-like
        /// objects). Equivalent to `get-prop` with a stringified index
        /// but avoids the allocation.
        get-prop-index: func(index: u32) -> result<handle, js-error>;

        /// Set a property. The value handle must belong to the same context.
        set-prop: func(key: string, val: borrow<handle>) -> result<_, js-error>;

        /// Call this handle as a function. `this-val` of `none` means the
        /// global object (JS non-strict default); pass a handle to use an
        /// explicit receiver.
        call: func(
            this-val: option<borrow<handle>>,
            args: list<borrow<handle>>
        ) -> result<handle, js-error>;

        /// Convenience: call a method by name. Equivalent to
        /// `get-prop(name).call(this=self, args)`.
        call-method: func(name: string, args: list<borrow<handle>>)
            -> result<handle, js-error>;

        /// Call this handle as a constructor (equivalent to `new self(...)`).
        new-instance: func(args: list<borrow<handle>>)
            -> result<handle, js-error>;

        /// Marshal out as a `value`. Fails if the handle holds a function,
        /// symbol, or contains circular references.
        to-value: func() -> result<value, js-error>;

        /// Structural type tag. Cheap — doesn't traverse the value.
        type-of: func() -> value-kind;

        /// True if this handle is a Promise.
        is-promise: func() -> bool;

        /// If this is a pending Promise, drive `run-pending-jobs` until it
        /// settles (or `deadline-ns` elapses, where `deadline-ns` is an
        /// absolute monotonic-clock value — the host sets it, the component
        /// compares against `host-interrupt`). Returns the resolved value
        /// as a handle, or raises the rejection reason as a `js-error`.
        await-promise: func(deadline-ns: option<u64>)
            -> result<handle, js-error>;
    }

    /// Cheap structural tag for a handle's underlying JS value.
    enum value-kind {
        %null,
        undefined,
        %boolean,
        number,
        bigint,
        %string,
        symbol,
        object,
        %function,
        array,
    }
}

/// The canonical QuickJS-hosting world for synchronous hosts.
/// Any host implementing these imports can run this component.
world quickjs {
    /// Dispatched when JS calls a host-registered function.
    /// `fn-id` is the integer the host previously passed to
    /// `register-host-function`. Arguments are marshaled as values;
    /// the host returns a value or raises a JS error.
    ///
    /// For the async story, see `quickjs-async` (future).
    import host-call: func(
        fn-id: u32,
        args: list<types.value>
    ) -> result<types.value, types.js-error>;

    /// Called periodically by QuickJS during execution. Return true to
    /// abort the currently running JS code. The host typically checks
    /// a wall-clock deadline here, and/or an atomic cancellation flag.
    import host-interrupt: func() -> bool;

    export types;
    export runtime;
    export context;
}

/// Future: an async world built on WASI 0.3 futures/streams for
/// non-blocking host functions. Sketched here to preserve shape; not
/// implemented in v0.1.
///
/// world quickjs-async {
///     import host-call-async: func(
///         fn-id: u32,
///         args: list<types.value>
///     ) -> future<result<types.value, types.js-error>>;
///     import host-interrupt: func() -> bool;
///     export types;
///     export runtime;
///     export context;
/// }
